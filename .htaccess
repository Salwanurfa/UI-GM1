# Disable directory browsing
Options All -Indexes

# ----------------------------------------------------------------------
# PHP Configuration for File Uploads
# ----------------------------------------------------------------------
<IfModule mod_php.c>
    # Maximum file upload size (10MB)
    php_value upload_max_filesize 10M
    # Maximum POST data size (12MB to accommodate form data + file)
    php_value post_max_size 12M
    # Maximum execution time for uploads (5 minutes)
    php_value max_execution_time 300
    # Maximum input time (5 minutes)
    php_value max_input_time 300
    # Memory limit (64MB)
    php_value memory_limit 64M
</IfModule>

# ----------------------------------------------------------------------
# Rewrite engine
# ----------------------------------------------------------------------

# Turning on the rewrite engine is necessary for the following rules and features.
# FollowSymLinks must be enabled for this to work.
<IfModule mod_rewrite.c>
	Options +FollowSymlinks
	RewriteEngine On

	# If you installed CodeIgniter in a subfolder, you will need to
	# change the following line to match the subfolder you need.
	# http://httpd.apache.org/docs/current/mod/mod_rewrite.html#rewritebase
	# RewriteBase /

	# Redirect to public folder
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^(.*)$ public/$1 [L]

	# Handle requests to public folder
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^public/(.*)$ public/index.php/$1 [L,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
	# If we don't have mod_rewrite installed, all 404's
	# can be sent to public/index.php, and everything works as normal.
	ErrorDocument 404 public/index.php
</IfModule>

# Disable server signature start
	ServerSignature Off
# Disable server signature end